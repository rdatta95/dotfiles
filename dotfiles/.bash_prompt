if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
  export TERM=gnome-256color
elif infocmp xterm-256color >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

# disable the default virtualenv prompt change
export VIRTUAL_ENV_DISABLE_PROMPT=1

if tput setaf 1 &> /dev/null; then
  tput sgr0
  if [[ $(tput colors) -ge 256 ]] 2>/dev/null; then
    # Changed these colors to fit Solarized theme
    YELLOW=$(tput setaf 37)
    MAGENTA=$(tput setaf 125)
    ORANGE=$(tput setaf 166)
    GREEN=$(tput setaf 157)
    PURPLE=$(tput setaf 61)
    WHITE=$(tput setaf 230)
  else
    YELLOW=$(tput setaf 3)
    MAGENTA=$(tput setaf 5)
    ORANGE=$(tput setaf 4)
    GREEN=$(tput setaf 2)
    PURPLE=$(tput setaf 1)
    WHITE=$(tput setaf 7)
  fi
  BOLD=$(tput bold)
  RESET=$(tput sgr0)
else
  YELLOW="\033[0;33m"
  MAGENTA="\033[1;31m"
  ORANGE="\033[1;33m"
  GREEN="\033[1;32m"
  # PURPLE="\033[1;35m"
  PURPLE="\033[1;34m"
  WHITE="\033[1;37m"
  BOLD=""
  RESET="\033[m"
fi

export YELLOW
export MAGENTA
export ORANGE
export GREEN
export PURPLE
export WHITE
export BOLD
export RESET

function get_date_time() {
  echo "\[${PURPLE}\][\D{%F %T}]"
}

function get_user() {
    echo "\[${GREEN}\]$(whoami | grep -oP '^[a-zA-Z0-9\-_]+')"
}

function get_ip() {
    my_ip="$(ip route get 8.8.8.8 | head -1 | cut -d' ' -f7)"
    pattern="[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$"
    if [[ $my_ip =~ $pattern ]]; then
        echo "(${my_ip})"
    fi
}

function get_network() {
  echo "\[${GREEN}\]@ \h $(get_ip)"
}

function get_current_path() {
  echo "\[\033[1;36m\][\w]"
}

function get_git_info() {
  GIT_PS1_SHOWDIRTYSTATE=1
  echo "\[${ORANGE}\]$(__git_ps1 '(%s)')"
}

function get_venv_info(){
    # Get Virtual Env
    if [[ -n "$VIRTUAL_ENV" ]]; then
        # Strip out the path and just leave the env name
        venv="${VIRTUAL_ENV##*/}"
    else
        # In case you don't have one activated
        venv=''
    fi
    [[ -n "$venv" ]] && echo "\[${ORANGE}\](venv:$venv)"
}

function get_prompt_symbol_ps1() {
  echo "\[$RESET\]\$"
}

function get_prompt_symbol_ps2() {
  echo "\[$RESET\]>"
}

function build_ps1_prompt() {
  PS1="\n$(get_date_time) $(get_user) $(get_network)\n$(get_current_path) $(get_git_info)\n$(get_venv_info)$(get_prompt_symbol_ps1) \[$RESET\]"
}

export PROMPT_COMMAND=build_ps1_prompt
export PS2="$(get_prompt_symbol_ps2) \[$RESET\]"
